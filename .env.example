# Vault Router keeper — copy to .env (gitignored). Never commit real values.

KEEPER_RPC_URL=
KEEPER_VAULT_ADDRESS=
KEEPER_CHAIN_ID=42161            # Arbitrum One

# Name of the env var that holds the curator private key. The key itself is
# read from THAT variable at runtime — it is never stored in this file or code.
KEEPER_KEY_ENV=KEEPER_PRIVATE_KEY

# Dry-run logs intended actions without signing/sending. Keep true until a real
# executor + bindings are wired.
KEEPER_DRY_RUN=true

# Cadence (Go duration strings)
KEEPER_POLL_INTERVAL=30s
KEEPER_GUARD_INTERVAL=5m
KEEPER_HARVEST_INTERVAL=6h
KEEPER_REBALANCE_MIN_INTERVAL=1h
